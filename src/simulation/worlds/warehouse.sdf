        <collision name="collision">
          <pose>0 0 0.1 0 0 0</pose>
          <geometry><cylinder><radius>0.035</radius><length>0.2</length></cylinder></geometry>
        </collision>
      </link>

      <joint name="joint3" type="revolute">
        <parent>link2</parent>
        <child>link3</child>
        <pose>0 0 0.3 0 0 0</pose>
        <axis>
          <xyz>0 0 1</xyz>
          <limit><lower>-2.8973</lower><upper>2.8973</upper><effort>87</effort><velocity>2.175</velocity></limit>
        </axis>
      </joint>

      <!-- Link 4 -->
      <link name="link4">
        <pose relative_to="joint4"/>
        <inertial>
          <pose>0 0 0.1 0 0 0</pose>
          <mass>1.5</mass>
