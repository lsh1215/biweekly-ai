        <collision name="collision">
          <pose>0 0 0.05 0 0 0</pose>
          <geometry><cylinder><radius>0.025</radius><length>0.1</length></cylinder></geometry>
        </collision>
      </link>

      <joint name="joint6" type="revolute">
        <parent>link5</parent>
        <child>link6</child>
        <pose>0 0 0.15 0 0 0</pose>
        <axis>
          <xyz>0 1 0</xyz>
          <limit><lower>-0.0175</lower><upper>3.7525</upper><effort>12</effort><velocity>2.61</velocity></limit>
        </axis>
      </joint>

      <!-- Gripper (simplified as a prismatic joint pair) -->
      <link name="gripper_left">
        <pose relative_to="gripper_joint_left"/>
        <inertial>
          <mass>0.1</mass>
          <inertia>
            <ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz>
          </inertia>
        </inertial>
        <visual name="visual">
          <geometry><box><size>0.01 0.02 0.06</size></box></geometry>
          <material><ambient>0.5 0.5 0.5 1</ambient><diffuse>0.6 0.6 0.6 1</diffuse></material>
        </visual>
        <collision name="collision">
          <geometry><box><size>0.01 0.02 0.06</size></box></geometry>
        </collision>
      </link>

      <joint name="gripper_joint_left" type="prismatic">
        <parent>link6</parent>
        <child>gripper_left</child>
        <pose>0 -0.02 0.1 0 0 0</pose>
        <axis>
          <xyz>0 1 0</xyz>
          <limit><lower>0</lower><upper>0.04</upper><effort>20</effort><velocity>0.2</velocity></limit>
        </axis>
      </joint>

      <link name="gripper_right">
        <pose relative_to="gripper_joint_right"/>
        <inertial>
          <mass>0.1</mass>
          <inertia>
            <ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz>
          </inertia>
        </inertial>
        <visual name="visual">
          <geometry><box><size>0.01 0.02 0.06</size></box></geometry>
          <material><ambient>0.5 0.5 0.5 1</ambient><diffuse>0.6 0.6 0.6 1</diffuse></material>
        </visual>
        <collision name="collision">
          <geometry><box><size>0.01 0.02 0.06</size></box></geometry>
        </collision>
      </link>

      <joint name="gripper_joint_right" type="prismatic">
        <parent>link6</parent>
        <child>gripper_right</child>
        <pose>0 0.02 0.1 0 0 0</pose>
        <axis>
          <xyz>0 -1 0</xyz>
          <limit><lower>0</lower><upper>0.04</upper><effort>20</effort><velocity>0.2</velocity></limit>
        </axis>
      </joint>

      <!-- Joint position controller plugin -->
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>joint1</joint_name>
        <p_gain>100</p_gain>
        <i_gain>0.1</i_gain>
        <d_gain>10</d_gain>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>joint2</joint_name>
        <p_gain>100</p_gain>
        <i_gain>0.1</i_gain>
        <d_gain>10</d_gain>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>joint3</joint_name>
        <p_gain>100</p_gain>
        <i_gain>0.1</i_gain>
        <d_gain>10</d_gain>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>joint4</joint_name>
        <p_gain>100</p_gain>
        <i_gain>0.1</i_gain>
        <d_gain>10</d_gain>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>joint5</joint_name>
        <p_gain>50</p_gain>
        <i_gain>0.1</i_gain>
        <d_gain>5</d_gain>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>joint6</joint_name>
        <p_gain>50</p_gain>
        <i_gain>0.1</i_gain>
        <d_gain>5</d_gain>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>gripper_joint_left</joint_name>
        <p_gain>100</p_gain>
        <i_gain>0.1</i_gain>
        <d_gain>1</d_gain>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>gripper_joint_right</joint_name>
        <p_gain>100</p_gain>
        <i_gain>0.1</i_gain>
        <d_gain>1</d_gain>
      </plugin>

      <!-- Joint state publisher -->
      <plugin filename="gz-sim-joint-state-publisher-system"
              name="gz::sim::systems::JointStatePublisher"/>
    </model>

    <!-- ==================== OVERHEAD CAMERA ==================== -->
    <model name="overhead_camera">
      <static>true</static>
      <pose>1.0 0.0 3.0 0 1.5708 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>0.05 0.05 0.05</size></box></geometry>
          <material><ambient>0 0 0 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
        </visual>
        <sensor name="camera" type="camera">
          <always_on>1</always_on>
          <update_rate>30</update_rate>
          <camera>
            <horizontal_fov>1.5708</horizontal_fov>
            <image>
              <width>640</width>
              <height>480</height>
              <format>R8G8B8</format>
            </image>
            <clip>
              <near>0.1</near>
              <far>10</far>
            </clip>
          </camera>
          <topic>camera</topic>
        </sensor>
      </link>
    </model>

  </world>
</sdf>
