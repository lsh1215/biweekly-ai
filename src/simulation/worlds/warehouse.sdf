        </visual>
        <collision name="collision">
          <pose>0 0 0.15 0 0 0</pose>
          <geometry><cylinder><radius>0.04</radius><length>0.3</length></cylinder></geometry>
        </collision>
      </link>

      <joint name="joint2" type="revolute">
        <parent>link1</parent>
        <child>link2</child>
        <pose>0 0 0.3 0 0 0</pose>
        <axis>
          <xyz>0 1 0</xyz>
          <limit><lower>-1.7628</lower><upper>1.7628</upper><effort>87</effort><velocity>2.175</velocity></limit>
        </axis>
      </joint>

      <!-- Link 3 -->
      <link name="link3">
        <pose relative_to="joint3"/>
        <inertial>
          <pose>0 0 0.1 0 0 0</pose>
          <mass>1.5</mass>
          <inertia>
            <ixx>0.005</ixx><iyy>0.005</iyy><izz>0.001</izz>
          </inertia>
        </inertial>
        <visual name="visual">
          <pose>0 0 0.1 0 0 0</pose>
          <geometry><cylinder><radius>0.035</radius><length>0.2</length></cylinder></geometry>
          <material><ambient>0.9 0.9 0.9 1</ambient><diffuse>0.95 0.95 0.95 1</diffuse></material>
