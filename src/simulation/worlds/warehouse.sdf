    <!-- ==================== COLLECTION BOX ==================== -->
    <model name="collection_box">
      <static>true</static>
      <pose>-1.0 0.0 0.0 0 0 0</pose>
      <link name="link">
        <!-- Bottom -->
        <visual name="bottom">
          <pose>0 0 0.01 0 0 0</pose>
          <geometry><box><size>0.5 0.5 0.02</size></box></geometry>
          <material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.4 0.4 0.4 1</diffuse></material>
