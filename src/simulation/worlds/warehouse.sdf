        </visual>
      </link>
    </model>

    <!-- Box (brown box) on Shelf B slot 1 -->
    <model name="box">
      <pose>2.0 2.1 0.46 0 0 0</pose>
      <link name="link">
        <inertial>
          <mass>0.5</mass>
          <inertia>
            <ixx>0.000833</ixx><iyy>0.000833</iyy><izz>0.000833</izz>
