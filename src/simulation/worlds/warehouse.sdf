<?xml version="1.0" ?>
<sdf version="1.9">
  <world name="warehouse">

    <!-- Physics -->
    <physics name="1ms" type="dart">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <!-- Plugins -->
    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>

    <!-- Lighting -->
    <light type="directional" name="warehouse_light">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 5 0 0 0</pose>
      <diffuse>0.9 0.9 0.9 1</diffuse>
      <specular>0.3 0.3 0.3 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <light type="point" name="fill_light">
      <pose>0 0 3 0 0 0</pose>
      <diffuse>0.4 0.4 0.4 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <attenuation>
        <range>10</range>
        <constant>0.5</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
    </light>

    <!-- Ground plane -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane><normal>0 0 1</normal><size>10 10</size></plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane><normal>0 0 1</normal><size>10 10</size></plane>
          </geometry>
          <material>
            <ambient>0.6 0.6 0.6 1</ambient>
            <diffuse>0.6 0.6 0.6 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ==================== SHELF A ==================== -->
    <model name="shelf_A">
      <static>true</static>
      <pose>2.0 0.0 0.0 0 0 0</pose>
      <link name="shelf_body">
        <!-- Left side panel -->
        <visual name="left_panel">
          <pose>0 -0.3 0.5 0 0 0</pose>
          <geometry><box><size>0.4 0.02 1.0</size></box></geometry>
          <material><ambient>0.5 0.3 0.1 1</ambient><diffuse>0.6 0.4 0.2 1</diffuse></material>
        </visual>
        <collision name="left_panel_col">
          <pose>0 -0.3 0.5 0 0 0</pose>
          <geometry><box><size>0.4 0.02 1.0</size></box></geometry>
        </collision>
        <!-- Right side panel -->
        <visual name="right_panel">
          <pose>0 0.3 0.5 0 0 0</pose>
          <geometry><box><size>0.4 0.02 1.0</size></box></geometry>
          <material><ambient>0.5 0.3 0.1 1</ambient><diffuse>0.6 0.4 0.2 1</diffuse></material>
        </visual>
        <collision name="right_panel_col">
          <pose>0 0.3 0.5 0 0 0</pose>
          <geometry><box><size>0.4 0.02 1.0</size></box></geometry>
        </collision>
        <!-- Shelf surface -->
        <visual name="shelf_surface">
          <pose>0 0 0.4 0 0 0</pose>
          <geometry><box><size>0.4 0.6 0.02</size></box></geometry>
          <material><ambient>0.5 0.3 0.1 1</ambient><diffuse>0.6 0.4 0.2 1</diffuse></material>
        </visual>
        <collision name="shelf_surface_col">
          <pose>0 0 0.4 0 0 0</pose>
          <geometry><box><size>0.4 0.6 0.02</size></box></geometry>
        </collision>
      </link>
    </model>

    <!-- ==================== SHELF B ==================== -->
    <model name="shelf_B">
      <static>true</static>
      <pose>2.0 2.0 0.0 0 0 0</pose>
      <link name="shelf_body">
        <visual name="left_panel">
          <pose>0 -0.3 0.5 0 0 0</pose>
          <geometry><box><size>0.4 0.02 1.0</size></box></geometry>
          <material><ambient>0.5 0.3 0.1 1</ambient><diffuse>0.6 0.4 0.2 1</diffuse></material>
        </visual>
        <collision name="left_panel_col">
          <pose>0 -0.3 0.5 0 0 0</pose>
          <geometry><box><size>0.4 0.02 1.0</size></box></geometry>
        </collision>
        <visual name="right_panel">
          <pose>0 0.3 0.5 0 0 0</pose>
          <geometry><box><size>0.4 0.02 1.0</size></box></geometry>
          <material><ambient>0.5 0.3 0.1 1</ambient><diffuse>0.6 0.4 0.2 1</diffuse></material>
        </visual>
        <collision name="right_panel_col">
          <pose>0 0.3 0.5 0 0 0</pose>
          <geometry><box><size>0.4 0.02 1.0</size></box></geometry>
        </collision>
        <visual name="shelf_surface">
          <pose>0 0 0.4 0 0 0</pose>
          <geometry><box><size>0.4 0.6 0.02</size></box></geometry>
          <material><ambient>0.5 0.3 0.1 1</ambient><diffuse>0.6 0.4 0.2 1</diffuse></material>
        </visual>
        <collision name="shelf_surface_col">
          <pose>0 0 0.4 0 0 0</pose>
          <geometry><box><size>0.4 0.6 0.02</size></box></geometry>
        </collision>
      </link>
    </model>

    <!-- ==================== SHELF C ==================== -->
    <model name="shelf_C">
      <static>true</static>
      <pose>2.0 -2.0 0.0 0 0 0</pose>
      <link name="shelf_body">
        <visual name="left_panel">
          <pose>0 -0.3 0.5 0 0 0</pose>
          <geometry><box><size>0.4 0.02 1.0</size></box></geometry>
          <material><ambient>0.5 0.3 0.1 1</ambient><diffuse>0.6 0.4 0.2 1</diffuse></material>
        </visual>
        <collision name="left_panel_col">
          <pose>0 -0.3 0.5 0 0 0</pose>
          <geometry><box><size>0.4 0.02 1.0</size></box></geometry>
        </collision>
        <visual name="right_panel">
          <pose>0 0.3 0.5 0 0 0</pose>
          <geometry><box><size>0.4 0.02 1.0</size></box></geometry>
          <material><ambient>0.5 0.3 0.1 1</ambient><diffuse>0.6 0.4 0.2 1</diffuse></material>
        </visual>
        <collision name="right_panel_col">
          <pose>0 0.3 0.5 0 0 0</pose>
          <geometry><box><size>0.4 0.02 1.0</size></box></geometry>
        </collision>
        <visual name="shelf_surface">
          <pose>0 0 0.4 0 0 0</pose>
          <geometry><box><size>0.4 0.6 0.02</size></box></geometry>
          <material><ambient>0.5 0.3 0.1 1</ambient><diffuse>0.6 0.4 0.2 1</diffuse></material>
        </visual>
        <collision name="shelf_surface_col">
          <pose>0 0 0.4 0 0 0</pose>
          <geometry><box><size>0.4 0.6 0.02</size></box></geometry>
        </collision>
      </link>
    </model>

    <!-- ==================== OBJECTS ==================== -->

    <!-- Apple (red sphere) on Shelf A slot 0 -->
    <model name="apple">
      <pose>2.0 -0.1 0.45 0 0 0</pose>
      <link name="link">
        <inertial>
          <mass>0.2</mass>
          <inertia>
            <ixx>0.000128</ixx><iyy>0.000128</iyy><izz>0.000128</izz>
          </inertia>
        </inertial>
        <collision name="collision">
          <geometry><sphere><radius>0.04</radius></sphere></geometry>
          <surface>
            <friction><ode><mu>0.8</mu><mu2>0.8</mu2></ode></friction>
          </surface>
        </collision>
        <visual name="visual">
          <geometry><sphere><radius>0.04</radius></sphere></geometry>
          <material><ambient>1.0 0.0 0.0 1</ambient><diffuse>1.0 0.1 0.1 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Bottle (blue cylinder) on Shelf A slot 1 -->
    <model name="bottle">
      <pose>2.0 0.1 0.485 0 0 0</pose>
      <link name="link">
